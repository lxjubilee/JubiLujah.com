# ============================================================================
# Jubilujah.com — environment configuration (copy to .env and adjust)
# ============================================================================

# ---- Database (PostgreSQL 16+) ---------------------------------------------
# When using docker-compose, this host/port match the `postgres` service.
DATABASE_URL=postgres://jubilee:jubilee_dev_pw@localhost:5432/jubilujah
PGSSLMODE=disable

# Production: the "jubilujah" database on the Seattle VPS (SEAIIS01SERVER).
# See docs/seattle-vps-db.md for provisioning. SSL is required for the remote hop.
# DATABASE_URL=postgres://jubilujah_app:<PASSWORD>@94.72.120.231:5432/jubilujah
# PGSSLMODE=require

# ---- API server -------------------------------------------------------------
API_PORT=4000
NODE_ENV=development
# Comma-separated list of allowed browser origins for CORS.
CORS_ORIGIN=http://localhost:3000
# Secret used to sign session/CSRF cookies. CHANGE IN PRODUCTION (32+ random bytes).
SESSION_SECRET=dev-only-change-me-please-32-bytes-min
# Cookie domain shared with jubileeinspire.com in production (e.g. .jubilee.example).
# Leave blank for localhost.
COOKIE_DOMAIN=
SESSION_TTL_HOURS=12

# ---- Login mode (where email/password is authenticated) --------------------
# 'local' (default): verify against identity.credentials in our own DB — the
#   dev / localhost behavior.
# 'ji': delegate POST /api/auth/signin to JubileeInspire's POST /api/auth/login
#   (production). JI is the credential authority; we forward the raw Turnstile
#   token (JI verifies it — do NOT verify locally), then upsert the returned user
#   and mint our own session. See services/jiLogin.js. Rollback = set back to
#   'local' + restart the api (no redeploy).
AUTH_LOGIN_MODE=local
# Base URL for JI's login API (falls back to JI_API_BASE, then the prod default).
JI_LOGIN_BASE=https://api.jubileeinspire.com
# Platform tag sent as `source` so JI knows which app the login came from.
JI_LOGIN_SOURCE=jubilujah

# ---- Outbound service calls to JubileeInspire (services/jiSync.js) ----------
# Base URL for JI's service/admin API: password sync, user provisioning, and the
# pre-signup GET /api/auth/check-email guard.
JI_API_BASE=https://api.jubileeinspire.com
# Client-credentials pair for JI's /api/auth/service/token. Leave empty in dev:
# password sync and provisioning then no-op, and check-email falls back to the
# unauthenticated call (public on UAT, Bearer-only in prod).
JI_SERVICE_CLIENT_ID=
JI_SERVICE_CLIENT_SECRET=
# Deadline for the pre-signup check-email call (token fetch included). It sits in
# the user's synchronous signup path; on timeout we fail open and allow the signup.
JI_CHECK_EMAIL_TIMEOUT_MS=4000

# ---- OIDC / Single Sign-On (JubileeInspire) --------------------------------
# In dev these point at the bundled mock-oidc provider. In production, point them
# at the real JubileeInspire identity provider (api.JubileeInspire.com) — no code
# changes required, only these values. See docs/sso-integration.md.
OIDC_ISSUER=http://localhost:4010
OIDC_CLIENT_ID=jubilujah-web
OIDC_CLIENT_SECRET=jubilujah-dev-secret
# Routed through the web origin (:3000) which proxies /api/* to the API, so the
# whole OIDC round-trip stays same-origin and session/CSRF cookies just work.
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback
# Where to send the user after a successful login (the web app).
WEB_BASE_URL=http://localhost:3000
OIDC_SCOPES=openid profile email roles

# ---- Auth: email (password reset + login OTP) ------------------------------
# Leave SENDGRID_API_KEY blank in dev: the email service logs the reset link /
# OTP code to the API console instead of sending. Set it in production.
SENDGRID_API_KEY=
EMAIL_FROM=Jubilujah <no-reply@jubilujah.com>
# Password reset link lifetime (minutes).
PASSWORD_RESET_TTL_MIN=60

# ---- Auth: Cloudflare Turnstile (sign-in CAPTCHA) --------------------------
# Leave both blank in dev: the server skips verification and the web renders no
# widget. Deploy the two keys (secret here, public below) together.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- Server-to-server admin/service auth (JWT, client-credentials) ----------
# Trusted partners (e.g. JubileeInspire) POST client_id+client_secret to
# /api/auth/service/token and receive a short-lived HS256 JWT, which they then
# present as `Authorization: Bearer <jwt>` on /api/auth/admin/*.
#
# SERVICE_JWT_SECRET signs AND verifies the JWTs (HS256). Leave blank to disable
# the service routes entirely (issuance => 503, admin routes => 401). Use a long,
# high-entropy value in production:  openssl rand -hex 32
SERVICE_JWT_SECRET=
# JWT iss/aud claims (verified on every admin call). Defaults shown.
SERVICE_JWT_ISSUER=https://api.jubilujah.com
SERVICE_JWT_AUDIENCE=jubilujah-admin
# Access-token lifetime in seconds (short-lived; clients re-fetch as needed).
SERVICE_TOKEN_TTL_SEC=600
# Registered clients: comma-separated entries "id:secret:scopeA|scopeB". Fields
# split on ":", scopes on "|". Omit the 3rd field for all scopes ("*"). Secrets
# must NOT contain , : | (use hex/base64url). Known scopes: admin.set_password,
# admin.provision.  Example:
#   SERVICE_CLIENTS=jubileeinspire:REPLACE_WITH_HEX_SECRET:admin.set_password|admin.provision
SERVICE_CLIENTS=
# Optional comma-separated IP allow-list (defense in depth). When set, a valid
# token from a non-listed IP is rejected with 403. Leave blank for token-only.
# NOTE: behind Cloudflare/nginx, ensure the real client IP reaches the app
# (req.ip) before relying on this.
ADMIN_SERVICE_ALLOW_IPS=
# Rate limit (requests / 15 min) for the per-client service limiter.
ADMIN_SERVICE_RATE_MAX=600

# ---- Catalog manifest -------------------------------------------------------
# Manifest is authoritative for the catalog (per ops doc). Both web and api read it.
MANIFEST_PATH=web/public/music/catalog-manifest.json
# CDN base for audio/art assets.
CDN_BASE=https://cdn.jubileeverse.com

# ---- mock-oidc dev provider -------------------------------------------------
MOCK_OIDC_PORT=4010
MOCK_OIDC_ISSUER=http://localhost:4010

# ---- Web (Next.js) ----------------------------------------------------------
# Public base URL of the Node API as seen from the browser.
NEXT_PUBLIC_API_BASE=http://localhost:4000
NEXT_PUBLIC_CDN_BASE=https://cdn.jubileeverse.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Public Cloudflare Turnstile site key (same pair as TURNSTILE_SECRET_KEY above).
# Blank => the sign-in page renders no Turnstile widget (dev).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Local album artwork store (J: drive backs the CDN). Used by the web /cover route.
ARTWORK_BASE=J:/music
