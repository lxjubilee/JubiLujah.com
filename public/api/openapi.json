      "Nomination":        { "$ref": "/schemas/v1/award.nomination.schema.json" },
      "NominationCreate":  { "$ref": "/schemas/v1/award.nomination.create.schema.json" },
      "NominationList":    { "$ref": "/schemas/v1/award.nomination-list.schema.json" },
      "AwardWinner":       { "$ref": "/schemas/v1/award.winner.schema.json" },
      "AwardWinnerCreate": { "$ref": "/schemas/v1/award.winner.create.schema.json" },

      "Station":            { "$ref": "/schemas/v1/station.schema.json" },
      "StationList":        { "$ref": "/schemas/v1/station.list.schema.json" },
      "Program":            { "$ref": "/schemas/v1/program.schema.json" },
      "ProgramList":        { "$ref": "/schemas/v1/program.list.schema.json" },
      "Playlist":           { "$ref": "/schemas/v1/playlist.schema.json" },
      "PlaylistCreate":     { "$ref": "/schemas/v1/playlist.create.schema.json" },
      "PlaylistList":       { "$ref": "/schemas/v1/playlist.list.schema.json" },
      "PlaylistItemsPatch": { "$ref": "/schemas/v1/playlist.items.patch.schema.json" },

      "PublishJob":     { "$ref": "/schemas/v1/admin.publish-job.schema.json" },
      "User":           { "$ref": "/schemas/v1/admin.user.schema.json" },
      "UserList":       { "$ref": "/schemas/v1/admin.user-list.schema.json" },
      "UserRolesPatch": { "$ref": "/schemas/v1/admin.user-roles.patch.schema.json" },
      "AuditEventList": { "$ref": "/schemas/v1/admin.audit-event-list.schema.json" }
    },
