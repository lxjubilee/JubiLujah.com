{
  "openapi": "3.1.0",
  "info": {
    "title": "Jubilujah Internal API",
    "version": "1.0.0",
    "summary": "Editorial, pipeline, ratings, awards, radio, and admin surface for Jubilujah.",
    "description": "OpenAPI 3.1 contract implementing every endpoint enumerated in Jubilujah Build Spec v1.0 §19 (API Surface — Initial). Authentication is delegated to JubileeInspire SSO (Build Spec §5); the resulting session cookie (`session_id`, HttpOnly/Secure/SameSite=Strict) authorizes all calls. All mutating requests require a CSRF token header (`X-CSRF-Token`). Role-based gates per §5: minimum `content_editor` for read; `production_manager` for pipeline transitions; `radio_producer` for playlist mutations; `admin` for `/admin/*`. Domain schemas live at `/schemas/v1/*.schema.json` and are referenced via `$ref` from this document.",
    "contact": {
      "name": "Gabriel Ungureanu — Stewardship",
      "url": "https://jubilujah.com"
    },
    "license": {
      "name": "Proprietary — Jubilee Music Internal Use Only",
      "identifier": "LicenseRef-Jubilee-Internal"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3119/api",
      "description": "Local development (server.js)"
    },
    {
      "url": "https://jubilujah.com/api",
      "description": "Production stub (gated by JubileeInspire SSO)"
    }
  ],
  "security": [
    {
      "cookieAuth": []
    }
  ],
  "tags": [
    { "name": "Catalog",  "description": "Artists, albums, songs, lyrics (Build Spec §7)." },
    { "name": "Pipeline", "description": "10-stage production pipeline (Build Spec §8)." },
    { "name": "Ratings",  "description": "Polymorphic 1-5 star ratings on rateable objects." },
    { "name": "Comments", "description": "Polymorphic threaded editorial comments." },
    { "name": "Awards",   "description": "Quarterly / annual award categories, periods, nominations, winners." },
    { "name": "Radio",    "description": "Stations, programs, and producer playlists (HM-band)." },
    { "name": "Admin",    "description": "Publish triggers, user/role admin, audit log (admin role only)." }
  ],
  "paths": {
    "/artists": {
      "get": {
        "tags": ["Catalog"],
        "operationId": "listArtists",
        "summary": "List artists, optionally filtered by grouping.",
        "parameters": [
          { "$ref": "#/components/parameters/GroupingQuery" },
          { "$ref": "#/components/parameters/LimitQuery" },
          { "$ref": "#/components/parameters/OffsetQuery" }
        ],
        "responses": {
          "200": {
            "description": "Page of artists.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ArtistList" },
                "examples": {
                  "inspireFamily": { "$ref": "#/components/examples/ArtistListInspireFamily" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "post": {
        "tags": ["Catalog"],
        "operationId": "createArtist",
        "summary": "Create a new artist (content_editor+).",
        "parameters": [{ "$ref": "#/components/parameters/CsrfHeader" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ArtistCreate" },
              "examples": {
                "affiliated": { "$ref": "#/components/examples/ArtistCreateAffiliated" }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Artist created.",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Artist" } }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      }
    },
    "/artists/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/IdPath" }],
      "get": {
        "tags": ["Catalog"],
        "operationId": "getArtist",
        "summary": "Fetch a single artist by id.",
        "responses": {
          "200": {
            "description": "Artist found.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Artist" },
                "examples": {
                  "melodyInspire": { "$ref": "#/components/examples/ArtistMelody" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "patch": {
        "tags": ["Catalog"],
        "operationId": "updateArtist",
        "summary": "Partial update of an artist record.",
        "parameters": [{ "$ref": "#/components/parameters/CsrfHeader" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/ArtistPatch" } }
          }
        },
        "responses": {
          "200": {
            "description": "Updated artist.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Artist" } } }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      }
    },
    "/albums": {
      "get": {
        "tags": ["Catalog"],
        "operationId": "listAlbums",
        "summary": "List albums, optionally scoped to one artist.",
        "parameters": [
          { "$ref": "#/components/parameters/ArtistIdQuery" },
          { "$ref": "#/components/parameters/LimitQuery" },
          { "$ref": "#/components/parameters/OffsetQuery" }
        ],
        "responses": {
          "200": {
            "description": "Page of albums.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AlbumList" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "post": {
        "tags": ["Catalog"],
        "operationId": "createAlbum",
        "summary": "Create a new album (Inspire Family albums must reach 12 songs before publish).",
        "parameters": [{ "$ref": "#/components/parameters/CsrfHeader" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/AlbumCreate" } }
          }
        },
        "responses": {
          "201": {
            "description": "Album created.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Album" } } }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      }
    },
    "/albums/{id}": {
