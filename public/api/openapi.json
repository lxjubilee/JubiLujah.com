              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "patch": {
        "tags": ["Catalog"],
        "operationId": "updateAlbum",
        "summary": "Partial update of an album.",
        "parameters": [{ "$ref": "#/components/parameters/CsrfHeader" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/AlbumPatch" } }
          }
        },
        "responses": {
          "200": {
            "description": "Updated album.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Album" } } }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      }
    },
    "/songs": {
      "get": {
        "tags": ["Catalog"],
        "operationId": "listSongs",
        "summary": "List songs, optionally scoped to one album.",
        "parameters": [
          { "$ref": "#/components/parameters/AlbumIdQuery" },
          { "$ref": "#/components/parameters/LimitQuery" },
          { "$ref": "#/components/parameters/OffsetQuery" }
        ],
        "responses": {
          "200": {
            "description": "Page of songs.",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/SongList" } }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "post": {
        "tags": ["Catalog"],
        "operationId": "createSong",
        "summary": "Create a new song under an album.",
