        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/LyricsReplace" } }
          }
        },
        "responses": {
          "200": {
            "description": "Lyrics replaced.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Lyrics" } } }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      }
    },
    "/pipeline": {
      "get": {
        "tags": ["Pipeline"],
        "operationId": "listPipeline",
        "summary": "List rateable objects currently in the production pipeline.",
        "parameters": [
          { "$ref": "#/components/parameters/StageQuery" },
          { "$ref": "#/components/parameters/LimitQuery" },
          { "$ref": "#/components/parameters/OffsetQuery" }
        ],
        "responses": {
          "200": {
            "description": "Pipeline snapshot.",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/PipelineList" } }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/pipeline/{type}/{id}/transition": {
      "parameters": [
        { "$ref": "#/components/parameters/RateableTypePath" },
        { "$ref": "#/components/parameters/IdPath" }
      ],
      "post": {
        "tags": ["Pipeline"],
        "operationId": "transitionPipeline",
        "summary": "Advance (or reverse) a pipeline object to a new stage. Append-only history.",
        "parameters": [{ "$ref": "#/components/parameters/CsrfHeader" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PipelineTransition" },
              "examples": {
                "advanceToQa": { "$ref": "#/components/examples/PipelineTransitionRequest" }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transition recorded.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PipelineHistoryEntry" },
                "examples": {
                  "qaReview": { "$ref": "#/components/examples/PipelineTransitionResponse" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      }
    },
    "/ratings/{type}/{id}": {
      "parameters": [
        { "$ref": "#/components/parameters/RateableTypePath" },
        { "$ref": "#/components/parameters/IdPath" }
      ],
      "get": {
        "tags": ["Ratings"],
        "operationId": "getRating",
        "summary": "Aggregate rating + distribution for a rateable object.",
        "responses": {
          "200": {
            "description": "Aggregate rating payload.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RatingAggregate" },
                "examples": {
                  "fiveStarSong": { "$ref": "#/components/examples/RatingAggregateExample" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Ratings"],
        "operationId": "upsertRating",
        "summary": "Upsert the current user's rating (1-5).",
        "parameters": [{ "$ref": "#/components/parameters/CsrfHeader" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RatingUpsert" },
              "examples": {
                "fiveStars": { "$ref": "#/components/examples/RatingUpsertRequest" }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rating stored.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Rating" } } }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      },
      "delete": {
        "tags": ["Ratings"],
        "operationId": "deleteRating",
        "summary": "Remove the current user's rating.",
        "parameters": [{ "$ref": "#/components/parameters/CsrfHeader" }],
        "responses": {
          "204": { "description": "Rating removed." },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
