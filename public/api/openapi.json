  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "session_id",
        "description": "HttpOnly + Secure + SameSite=Strict cookie issued by the backend after a successful JubileeInspire SSO exchange (Build Spec §5)."
      }
    },
    "parameters": {
      "IdPath": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "UUID of the resource.",
        "schema": { "type": "string", "format": "uuid" }
      },
      "CommentIdPath": {
        "name": "commentId",
        "in": "path",
        "required": true,
        "description": "UUID of the comment.",
        "schema": { "type": "string", "format": "uuid" }
      },
      "YearPath": {
        "name": "year",
        "in": "path",
        "required": true,
        "description": "Four-digit year (e.g. 2026).",
        "schema": { "type": "integer", "minimum": 2000, "maximum": 2999 }
      },
      "RateableTypePath": {
        "name": "type",
        "in": "path",
        "required": true,
        "description": "Polymorphic object type.",
        "schema": {
          "type": "string",
          "enum": ["song", "album", "artist", "lyrics", "playlist"]
        }
      },
      "CsrfHeader": {
        "name": "X-CSRF-Token",
        "in": "header",
        "required": true,
        "description": "Double-submit CSRF token issued at login (Build Spec §20).",
        "schema": { "type": "string", "minLength": 16 }
      },
      "GroupingQuery": {
        "name": "grouping",
        "in": "query",
        "required": false,
        "description": "Restrict to one artist grouping (Build Spec §6).",
        "schema": {
          "type": "string",
          "enum": ["inspire_family", "affiliated", "childrens_brands", "other_initiatives"]
        }
      },
      "ArtistIdQuery": {
        "name": "artist_id",
        "in": "query",
        "required": false,
        "description": "Scope to a single artist UUID.",
        "schema": { "type": "string", "format": "uuid" }
      },
      "AlbumIdQuery": {
        "name": "album_id",
        "in": "query",
        "required": false,
        "description": "Scope to a single album UUID.",
        "schema": { "type": "string", "format": "uuid" }
      },
      "StageQuery": {
        "name": "stage",
        "in": "query",
        "required": false,
        "description": "Pipeline stage to filter by (Build Spec §8).",
        "schema": {
          "type": "string",
          "enum": [
            "concept", "lyrics_drafting", "lyrics_approved", "song_generation",
            "qa_review", "engineering", "sunil_approval", "final_approval",
            "published", "distributed"
          ]
        }
      },
      "PeriodQuery": {
        "name": "period",
        "in": "query",
        "required": false,
        "description": "Four-digit year scoping nominations.",
        "schema": { "type": "integer", "minimum": 2000, "maximum": 2999 }
      },
      "CategoryQuery": {
        "name": "category",
        "in": "query",
        "required": false,
        "description": "Award category UUID.",
        "schema": { "type": "string", "format": "uuid" }
      },
      "SinceQuery": {
        "name": "since",
        "in": "query",
        "required": false,
        "description": "ISO-8601 timestamp; only events at or after this instant are returned.",
        "schema": { "type": "string", "format": "date-time" }
      },
      "LimitQuery": {
        "name": "limit",
        "in": "query",
        "required": false,
        "description": "Page size (default 50, max 200).",
        "schema": { "type": "integer", "minimum": 1, "maximum": 200, "default": 50 }
      },
      "OffsetQuery": {
        "name": "offset",
        "in": "query",
        "required": false,
        "description": "Pagination offset.",
        "schema": { "type": "integer", "minimum": 0, "default": 0 }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "No valid session cookie present.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "examples": {
              "missingSession": {
                "value": { "error": "unauthorized", "message": "Session required. Re-authenticate via JubileeInspire SSO." }
              }
            }
          }
        }
      },
      "Forbidden": {
        "description": "Authenticated but role does not satisfy the route's minimum.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "examples": {
              "needsAdmin": {
                "value": { "error": "forbidden", "message": "Role 'admin' required for this operation." }
              }
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource does not exist or is not visible to the caller.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "examples": {
              "missing": { "value": { "error": "not_found", "message": "Resource not found." } }
            }
          }
        }
      },
      "UnprocessableEntity": {
        "description": "Request body failed Pydantic / domain validation.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ValidationError" },
            "examples": {
              "hebrewArticle": {
                "value": {
                  "error": "validation_failed",
                  "message": "Hebrew article rule violation in lyrics.",
                  "details": [
                    { "field": "lyrics.text", "code": "hebrew_article_rule", "hint": "Use 'the Ruach Kodesh' or 'Ruach HaKodesh' — never 'the Ruach HaKodesh'." }
                  ]
                }
              }
            }
          }
        }
      }
    },
